# ============================================================
# Rackvio Community Edition — Environment Configuration
# ============================================================

# --- REQUIRED ---

# Email for the bootstrap admin account (first login)
PLATFORM_ADMIN_EMAIL=admin@yourcompany.com

# JWT signing secret — generate with: openssl rand -base64 48 | tr -d '=+/' | cut -c1-64
AUTH_SECRET=change-me-generate-a-64-char-random-string

# --- OPTIONAL (defaults are fine for evaluation) ---

# Database passwords — change these for production
DB_PASS=devpassword
APP_DB_PASS=devpassword
MIGRATIONS_DB_PASS=devpassword
